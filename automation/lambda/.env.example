# ──────────────────────────────────────────────────
# Jira Automation Lambda — Environment Variables
# Copy to .env and fill in real values
# ──────────────────────────────────────────────────

# ── Jira ──────────────────────────────────────────
JIRA_BASE_URL=your-domain.atlassian.net       # No https:// prefix needed
JIRA_EMAIL=you@example.com                     # Jira account email
JIRA_API_TOKEN=ATATT3x...                      # SECRET — Jira API token
JIRA_PROJECT_KEY=ST                            # Project key (e.g. ST, PROJ)
JIRA_WEBHOOK_SECRET=your-random-secret-here    # SECRET — shared secret for webhook auth

# ── GitHub ────────────────────────────────────────
GITHUB_TOKEN=ghp_xxxxxxxxxxxx                  # SECRET — PAT with repo + workflow scope
GITHUB_OWNER=lucasspi                          # GitHub user or org
GITHUB_REPO=react-automated                    # Target repository name

# ── Slack ─────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx  # SECRET — Incoming webhook URL

# ── AWS / DynamoDB ────────────────────────────────
DYNAMODB_TABLE=jira-agent-tasks                # DynamoDB table name
AWS_REGION=us-east-1                           # AWS region

# ── Jira Status Names (match your board columns) ─
TRIGGER_STATUS=TRIGGER AGENT                   # Column that triggers the agent
IN_PROGRESS_STATUS=IN PROGRESS                 # Column for "work started"
CODE_REVIEW_STATUS=CODE REVIEW                 # Column for "PR ready"
